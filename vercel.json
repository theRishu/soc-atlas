{
  "version": 2,
  "builds": [
    {
      "src": "build.sh",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "site"
      }
    }
  ],
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/networking/osi_tcpip",
      "destination": "/networking/osi_tcpip/index.html"
    },
    {
      "source": "/(v1|v2)?/(.*)",
      "destination": "/$2"
    }
  ]
}
